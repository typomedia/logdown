<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="robots" content="noindex, nofollow">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ application.name }}{% endblock %}</title>
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('themes/zuse/libs/bootstrap/css/bootstrap.css') }}">
        <link rel="stylesheet" href="{{ asset('themes/zuse/styles.css') }}">
{#        <link rel="icon" type="image/x-icon" href="{{ asset('themes/zuse/favicon.png') }}">#}
    {% endblock %}
</head>
{% set route = app.request.get('_route') %}
<body class="{{ route }}">
<header>
    <nav class="navbar">
        <div class="container-fluid">
            <div class="navbar-header">
                <a class="navbar-brand" href="{{ path('logs_index') }}"><span class="fa fa-wpexplorer"></span>&ensp;{{ application.name }}</a>
            </div>
            <form class="navbar-form navbar-right" method="get" action="{{ path('logs_index') }}">
                <div class="form-group">
                    <label>
                        <input type="text" name="search" class="form-control" value="" autofocus="autofocus" placeholder="Search...">
                    </label>
                </div>
                <button type="submit" class="btn btn-default"><span class="fa fa-search"></span></button>
            </form>
            <div class="collapse navbar-collapse" id="bs-example-navbar-collapse-1">
                <ul class="nav navbar-nav">
                    <li class="{% if route starts with 'logs' %}active{% endif %}">
                        <a href="{{ path('logs_index') }}"><span class="fa fa-bullseye"></span> Requests</a>
                    </li>
                    <li class="{% if route starts with 'app_about' %}active{% endif %}">
                        <a href="{{ path('app_about_info') }}"><span class="fa fa-info-circle"></span> About</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>
<section>
    {% block body %}
    {% endblock %}
</section>
<footer>
    <div>
        <span>&copy; {{ "now"|date("Y") }} Typomedia Foundation. <span class="hidden-xs">Developed with <i class="love">&hearts;</i> by Philipp Speck.</span></span>
        <span class="pull-right">Version {{ application.version }}</span>
    </div>
</footer>
{% block javascripts %}
    <script src="{{ asset('themes/zuse/libs/jquery/jquery.slim.min.js') }}"></script>
    <script src="{{ asset('themes/zuse/libs/jquery/plugins/tablesorter.min.js') }}"></script>
    <script>
        if (!window.localStorage['sf2/profiler/toolbar/displayState']) {
            window.localStorage['sf2/profiler/toolbar/displayState'] = 'none';
        }
        if ($('.sf-minitoolbar').length > 0) {
            $('section').css('margin-bottom', 0);
        }

        $('table.table').tablesorter();
    </script>
{% endblock %}
</body>
</html>